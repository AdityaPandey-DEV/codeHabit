// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  username         String   @unique
  email            String   @unique
  password         String 
  leetcodeUsername String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  habits             Habit[]
  leetcodeSubmissions LeetCodeSubmission[]
  dailySnapshots     DailySnapshot[]
}

enum Frequency {
  DAILY
  WEEKLY
}

enum Category {
  HEALTH
  STUDY
  CODING
  OTHER
}

model Habit {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  name            String
  description     String?
  targetFrequency Frequency @default(DAILY)
  category        Category  @default(OTHER)
  
  logs            HabitLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum HabitStatus {
  COMPLETED
  MISSED
  SKIPPED
}

model HabitLog {
  id        String      @id @default(uuid())
  habitId   String
  habit     Habit       @relation(fields: [habitId], references: [id])
  date      DateTime
  status    HabitStatus
  metadata  Json?       // Stores things like { duration: 30, mood: 5 }
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([habitId, date])
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  ACCEPTED
  WRONG_ANSWER
  TLE
  RUNTIME_ERROR
  COMPILE_ERROR
  OTHER
}

model LeetCodeSubmission {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  problemTitle String
  problemSlug  String
  difficulty   Difficulty
  status       SubmissionStatus
  submittedAt  DateTime
  language     String?
  
  createdAt    DateTime @default(now())
}

model DailySnapshot {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  date            DateTime
  habitsCompleted Int
  problemsSolved  Int
  studyMinutes    Int
  moodScore       Float?
  
  createdAt       DateTime @default(now())

  @@unique([userId, date])
}
